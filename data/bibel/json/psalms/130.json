  "citation": "Psalmen 130 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Wallfahrtslied</em>. Aus der Tiefe rufe ich, HERR, zu dir:",
      "citation": "Psalmen 130:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "»Allherr, höre auf meine Stimme, laß deine Ohren merken auf mein lautes Flehen!«",
      "citation": "Psalmen 130:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Wenn du, HERR, Sünden behalten willst, o Allherr, wer kann bestehn!",
      "citation": "Psalmen 130:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Doch bei dir ist die Vergebung, auf daß man dich fürchte.",
      "citation": "Psalmen 130:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Ich harre des HERRN, meine Seele harrt, und ich warte auf sein Wort;",
      "citation": "Psalmen 130:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "meine Seele harrt auf den Allherrn sehnsuchtsvoller als Wächter auf den Morgen.",
      "citation": "Psalmen 130:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Sehnsuchtsvoller als Wächter auf den Morgen harre, Israel, auf den HERRN! Denn beim HERRN ist die Gnade und Erlösung bei ihm in Fülle,",
      "citation": "Psalmen 130:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "und er wird Israel erlösen von allen seinen Sünden.",
      "citation": "Psalmen 130:8 (Menge)"
    }
  ]
}
