  "citation": "Psalmen 113 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "Halleluja! Lobet, ihr Knechte des HERRN, lobet den Namen des HERRN!",
      "citation": "Psalmen 113:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Gepriesen sei der Name des HERRN von nun an bis in Ewigkeit!",
      "citation": "Psalmen 113:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Vom Aufgang der Sonne bis zu ihrem Niedergang sei gelobt der Name des HERRN!",
      "citation": "Psalmen 113:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Erhaben über alle Völker ist der HERR, den Himmel überragt seine Herrlichkeit!",
      "citation": "Psalmen 113:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Wer ist dem HERRN gleich, unserm Gott, der da thront in der Höhe,",
      "citation": "Psalmen 113:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "der niederschaut in die Tiefe, im Himmel und auf Erden?",
      "citation": "Psalmen 113:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Er hebt aus dem Staub den Geringen empor und erhöht aus dem Schmutz den Armen,",
      "citation": "Psalmen 113:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "um ihn sitzen zu lassen neben Edlen, neben den Edlen seines Volks.",
      "citation": "Psalmen 113:8 (Menge)"
    },
    {
      "verse": 9,
      "text": "Er verleiht der kinderlosen Gattin Hausrecht, macht sie zur fröhlichen Mutter von Kindern. Halleluja!",
      "citation": "Psalmen 113:9 (Menge)"
    }
  ]
}
