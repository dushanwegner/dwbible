  "citation": "Psalmen 150 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "Halleluja! Lobt Gott in seinem (himmlischen) Heiligtum, lobt ihn in seiner starken Feste!",
      "citation": "Psalmen 150:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Lobt ihn ob seinen Wundertaten, lobt ihn nach seiner gewaltigen Größe!",
      "citation": "Psalmen 150:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Lobt ihn mit Posaunenschall, lobt ihn mit Harfe und Zither!",
      "citation": "Psalmen 150:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Lobt ihn mit Pauke und Reigentanz, lobt ihn mit Saitenspiel und Flöte!",
      "citation": "Psalmen 150:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Lobt ihn mit hellklingenden Zimbeln, lobt ihn mit lautschallenden Zimbeln!",
      "citation": "Psalmen 150:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Alles, was Odem hat, lobe den HERRN! Halleluja!",
      "citation": "Psalmen 150:6 (Menge)"
    }
  ]
