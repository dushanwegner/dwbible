  "citation": "Psalmen 149 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "Halleluja! Singet dem HERRN ein neues Lied, seinen Lobpreis in der Versammlung der Frommen!",
      "citation": "Psalmen 149:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Es freue sich Israel seines Schöpfers, Zions Söhne sollen jubeln ob ihrem König!",
      "citation": "Psalmen 149:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Sie sollen seinen Namen preisen im Reigentanz, mit Pauken und Zithern ihm spielen!",
      "citation": "Psalmen 149:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Denn der HERR hat Wohlgefallen an seinem Volk; er schmückt die Gebeugten mit Sieg.",
      "citation": "Psalmen 149:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Frohlocken sollen die Frommen mit Stolz, sollen jauchzen auf ihren Lagern,",
      "citation": "Psalmen 149:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Lobeserhebungen Gottes im Mund und ein doppelschneidiges Schwert in der Hand:",
      "citation": "Psalmen 149:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "um Rache zu vollziehn an den Heiden, Vergeltung an den Völkern,",
      "citation": "Psalmen 149:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "um ihre Könige mit Ketten zu binden und ihre Edlen mit eisernen Fesseln,",
      "citation": "Psalmen 149:8 (Menge)"
    },
    {
      "verse": 9,
      "text": "um das längst geschriebene Urteil an ihnen zu vollstrecken: eine Ehre ist dies für alle seine Frommen! Halleluja!",
      "citation": "Psalmen 149:9 (Menge)"
    }
  ]
}
