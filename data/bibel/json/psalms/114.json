  "citation": "Psalmen 114 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "Halleluja! Als Israel aus Ägypten auszog, Jakobs Haus aus dem Volk fremder Sprache,",
      "citation": "Psalmen 114:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "da ward Juda sein Heiligtum, Israel sein Herrschaftsgebiet.",
      "citation": "Psalmen 114:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Das Meer sah es und floh, der Jordan wandte sich rückwärts,",
      "citation": "Psalmen 114:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "die Berge hüpften wie Widder, die Hügel gleichwie Lämmer.",
      "citation": "Psalmen 114:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Was war dir, o Meer, daß du flohest, dir, Jordan, daß du dich rückwärts wandtest?",
      "citation": "Psalmen 114:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "(Was war euch) ihr Berge, daß ihr hüpftet wie Widder, ihr Hügel gleichwie Lämmer?",
      "citation": "Psalmen 114:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Vor dem Anblick des Herrn erbebe, du Erde, vor dem Anblick des Gottes Jakobs,",
      "citation": "Psalmen 114:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "der Felsen wandelt zum Wasserteich, Kieselgestein zum sprudelnden Quell!",
      "citation": "Psalmen 114:8 (Menge)"
    }
  ]
}
