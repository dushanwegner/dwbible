  "citation": "Psalmen 100 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Psalm als Dankbezeigung</em>. Jauchzet dem HERRN, alle Lande,",
      "citation": "Psalmen 100:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "dienet dem HERRN mit Freuden, kommt vor sein Angesicht mit Jubel!",
      "citation": "Psalmen 100:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Erkennt, daß der HERR Gott ist! Er hat uns geschaffen, und sein sind wir, sein Volk und die Herde, die er weidet.",
      "citation": "Psalmen 100:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Zieht ein durch seine Tore mit Danken, in seines Tempels Höfe mit Lobgesang, dankt ihm, preist seinen Namen!",
      "citation": "Psalmen 100:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Denn freundlich ist der HERR, seine Gnade währt ewig und seine Treue von Geschlecht zu Geschlecht.",
      "citation": "Psalmen 100:5 (Menge)"
    }
  ]
