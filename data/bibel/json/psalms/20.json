  "citation": "Psalmen 20 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Dem Musikmeister; ein Psalm von David.</em>",
      "citation": "Psalmen 20:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Der HERR erhöre dich am Tage der Drangsal, es schütze dich der Name des Gottes Jakobs!",
      "citation": "Psalmen 20:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Er sende dir Hilfe vom Heiligtum her und leiste dir Beistand von Zion aus!",
      "citation": "Psalmen 20:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Er gedenke aller deiner Speisopfer und sehe dein Brandopfer wohlgefällig an! SELA.",
      "citation": "Psalmen 20:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Er gewähre dir, was dein Herz begehrt, und lasse all deine Pläne gelingen!",
      "citation": "Psalmen 20:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Dann wollen wir jubeln ob deinem Heil und im Namen unsers Gottes die Fahnen entfalten: der HERR erfülle dir all deine Wünsche! –",
      "citation": "Psalmen 20:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Jetzt weiß ich, der HERR hilft seinem Gesalbten: er erhört ihn aus seinem heiligen Himmel durch die hilfreichen Taten seiner Rechten.",
      "citation": "Psalmen 20:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "Diese sind stark durch Wagen und jene durch Rosse, doch wir sind stark durch den Namen des HERRN, unsers Gottes.",
      "citation": "Psalmen 20:8 (Menge)"
    },
    {
      "verse": 9,
      "text": "Sie stürzen nieder und fallen, doch wir stehn fest und halten uns aufrecht.",
      "citation": "Psalmen 20:9 (Menge)"
    },
    {
      "verse": 10,
      "text": "O HERR, hilf dem König! Erhör’ uns, sooft wir (dich) anrufen!",
      "citation": "Psalmen 20:10 (Menge)"
    }
  ]
}
