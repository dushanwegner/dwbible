  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Wallfahrtslied</em>. Wohlan, preiset den HERRN, alle ihr Diener des HERRN, die ihr steht in den Nächten im Hause des HERRN!",
      "citation": "Psalmen 134:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Erhebt eure Hände zum Heiligtum hin und preiset den HERRN!",
      "citation": "Psalmen 134:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Dich segne der HERR von Zion her, der Schöpfer von Himmel und Erde!",
      "citation": "Psalmen 134:3 (Menge)"
    }
  ]
