  "citation": "Psalmen 93 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "Der HERR ist König! Er hat sich gekleidet in Hoheit; in Hoheit hat der HERR sich gekleidet, mit Kraft umgürtet, auch der Erdkreis steht fest, so daß er nicht wankt.",
      "citation": "Psalmen 93:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Fest steht dein Thron von Anbeginn, von Ewigkeit her bist du.",
      "citation": "Psalmen 93:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Fluten erhoben, o HERR, Fluten erhoben ihr Brausen, Fluten werden (auch weiter) ihr Tosen erheben –",
      "citation": "Psalmen 93:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "mächtiger als das Brausen gewaltiger Wasser, mächtiger als die brandenden Meereswogen ist der HERR in der Himmelshöhe!",
      "citation": "Psalmen 93:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Was du verordnet hast, ist völlig zuverlässig, deinem Hause gebührt Heiligkeit, o HERR, für die Dauer der Zeiten.",
      "citation": "Psalmen 93:5 (Menge)"
    }
  ]
