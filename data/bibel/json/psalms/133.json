  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Wallfahrtslied</em> <em>Davids.</em> Seht, wie schön und wie lieblich ist’s, wenn Brüder auch (friedlich) beisammen wohnen!",
      "citation": "Psalmen 133:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Das gleicht dem köstlichen Öl auf dem Haupt, das herabtroff in den Bart, in Aarons Bart, der niederwallte auf den Saum seiner Gewandung.",
      "citation": "Psalmen 133:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Es gleicht dem Hermontau, der niederfällt auf die Berge Zions; denn dorthin hat der HERR den Segen entboten, Leben bis in Ewigkeit.",
      "citation": "Psalmen 133:3 (Menge)"
    }
  ]
