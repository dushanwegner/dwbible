  "citation": "Psalmen 23 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Psalm von David.</em> Der HERR ist mein Hirt: mir mangelt nichts.",
      "citation": "Psalmen 23:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Auf grünen Auen läßt er mich lagern, zum Lagerplatz am Bache führt er mich.",
      "citation": "Psalmen 23:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Er erquickt meine Seele; er leitet mich auf rechten Pfaden um seines Namens willen.",
      "citation": "Psalmen 23:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Müßt’ ich auch wandern in finsterm Tal: ich fürchte kein Unglück, denn du bist bei mir: dein Hirtenstab und dein Stecken, die sind mein Trost.",
      "citation": "Psalmen 23:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Du deckst mir reichlich den Tisch vor den Augen meiner Feinde; du salbst mir das Haupt mit Öl und schenkst mir den Becher voll ein.",
      "citation": "Psalmen 23:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Nur Gutes und Liebes werden mich begleiten mein ganzes Leben hindurch, und heimkehren werd’ ich zum Hause des HERRN für eine lange Reihe von Tagen.",
      "citation": "Psalmen 23:6 (Menge)"
    }
  ]
}
