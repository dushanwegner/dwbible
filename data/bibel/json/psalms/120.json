  "citation": "Psalmen 120 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Wallfahrtslied</em></em>. Ich rief zum HERRN in meiner Not: da erhörte er mich.",
      "citation": "Psalmen 120:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "O HERR, errette mich von der Lügenlippe, von der trügerischen Zunge!",
      "citation": "Psalmen 120:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Was wird Er dir jetzt und in Zukunft bescheren, du trügerische Zunge?",
      "citation": "Psalmen 120:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Geschärfte Kriegerpfeile samt Kohlen vom Ginsterstrauch!",
      "citation": "Psalmen 120:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Wehe mir, daß ich als Fremdling in Mesech weile, daß ich wohne bei den Zelten von Kedar!",
      "citation": "Psalmen 120:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Lange genug schon weile ich hier bei Leuten, die den Frieden hassen.",
      "citation": "Psalmen 120:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Ich bin ganz friedlich gestimmt, doch was ich auch rede: sie gehen auf Krieg aus.",
      "citation": "Psalmen 120:7 (Menge)"
    }
  ]
}
