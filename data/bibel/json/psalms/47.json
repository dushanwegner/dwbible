  "citation": "Psalmen 47 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Dem Musikmeister, von den Korahiten</em><em>, ein Psalm.</em>",
      "citation": "Psalmen 47:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Ihr Völker alle, klatscht in die Hände, jauchzet Gott mit Jubelrufen zu!",
      "citation": "Psalmen 47:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Denn der HERR, der Höchste, ist furchtbar, ein mächtiger König über die ganze Erde.",
      "citation": "Psalmen 47:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Er hat Völker unter unsre Herrschaft gebeugt und Völkerschaften unter unsre Füße;",
      "citation": "Psalmen 47:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "er hat uns unser Erbteil auserwählt, den Stolz Jakobs, den er liebt. SELA.",
      "citation": "Psalmen 47:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Aufgefahren ist Gott unter Jauchzen, der HERR beim Schall der Posaunen.",
      "citation": "Psalmen 47:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Lobsinget Gott, lobsinget, lobsingt unserm König, lobsinget!",
      "citation": "Psalmen 47:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "Denn König der ganzen Erde ist Gott: so singt ihm denn ein kunstvolles Lied!",
      "citation": "Psalmen 47:8 (Menge)"
    },
    {
      "verse": 9,
      "text": "Gott ist König geworden über die Völker, Gott hat sich gesetzt auf seinen heiligen Thron.",
      "citation": "Psalmen 47:9 (Menge)"
    },
    {
      "verse": 10,
      "text": "Die Edlen der Völker haben sich versammelt als das Volk des Gottes Abrahams; denn Gott sind untertan die Schilde der Erde: hoch erhaben steht er da.",
      "citation": "Psalmen 47:10 (Menge)"
    }
  ]
}
