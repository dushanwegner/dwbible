  "citation": "Psalmen 125 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Wallfahrtslied</em>. Die auf den HERRN vertrauen, die gleichen dem Berge Zion, der nicht wankt, der in Ewigkeit feststeht.",
      "citation": "Psalmen 125:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Wie Berge Jerusalem rings umgeben, so umhegt der HERR sein Volk von nun an bis in Ewigkeit.",
      "citation": "Psalmen 125:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Denn der Gottlosen Zepter wird nicht lasten bleiben auf dem Erbteil der Gerechten, damit nicht auch die Gerechten ihre Hände ausstrecken zum Frevel.",
      "citation": "Psalmen 125:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Erweise deine Güte, HERR, den Guten und denen, die redlichen Herzens sind!",
      "citation": "Psalmen 125:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Doch die auf ihre krummen Wege abbiegen, die lasse der HERR hinfahren mitsamt den Übeltätern! Heil über Israel!",
      "citation": "Psalmen 125:5 (Menge)"
    }
  ]
