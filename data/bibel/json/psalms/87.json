  "citation": "Psalmen 87 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Von den Korahiten ein Psalm, ein Lied.</em> Seine Gründung liegt auf heiligen Bergen:",
      "citation": "Psalmen 87:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "lieb hat der HERR die Tore Zions mehr als alle (anderen) Wohnstätten Jakobs.",
      "citation": "Psalmen 87:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Herrliches ist von dir berichtet, du Gottesstadt. SELA.",
      "citation": "Psalmen 87:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "»Ich nenne Ägypten und Babel als meine Bekenner, hier das Philisterland und Tyrus samt Äthiopien – nämlich wer dort seine Heimat hat.«",
      "citation": "Psalmen 87:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Doch von Zion heißt es: »Mann für Mann hat dort seine Heimat, und er selbst, der Höchste, macht es stark.«",
      "citation": "Psalmen 87:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Der HERR zählt, wenn er die Völker aufschreibt: »Dieser hat dort seine Heimat.« SELA.",
      "citation": "Psalmen 87:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Sie aber tanzen den Reigen und singen: »Alle meine Quellen sind in dir (o Zion)!«",
      "citation": "Psalmen 87:7 (Menge)"
    }
  ]
}
