  "citation": "Psalmen 122 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Wallfahrtslied</em> <em>Davids.</em> Ich freute mich, als man mir sagte: »Wir wollen pilgern zum Hause des HERRN!«",
      "citation": "Psalmen 122:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "So stehn denn nunmehr unsre Füße in deinen Toren, Jerusalem!",
      "citation": "Psalmen 122:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Jerusalem, du wiedererbaute als eine Stadt, die fest in sich geschlossen,",
      "citation": "Psalmen 122:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "wohin die Stämme hinaufziehn, die Stämme des HERRN, nach der für Israel gültigen Weisung, dort den Namen des HERRN zu preisen;",
      "citation": "Psalmen 122:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "denn dort waren einst aufgestellt die Stühle zum Gericht, die Stühle des Hauses Davids.",
      "citation": "Psalmen 122:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Bringet Jerusalem dar den Friedensgruß: »Heil denen, die dich lieben!",
      "citation": "Psalmen 122:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Friede herrsche vor deinen Mauern, sichere Ruhe in deinen Palästen!«",
      "citation": "Psalmen 122:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "Um meiner Brüder und Freunde willen will ich dir Frieden wünschen;",
      "citation": "Psalmen 122:8 (Menge)"
    },
    {
      "verse": 9,
      "text": "um des Hauses des HERRN, unsres Gottes, willen will ich Segen für dich erbitten.",
      "citation": "Psalmen 122:9 (Menge)"
    }
  ]
}
