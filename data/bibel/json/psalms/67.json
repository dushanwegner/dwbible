  "citation": "Psalmen 67 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Dem Musikmeister, mit Saitenspiel; ein Psalm, ein Lied.</em>",
      "citation": "Psalmen 67:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Gott sei uns gnädig und segne uns! Er lasse sein Angesicht bei uns leuchten, SELA,",
      "citation": "Psalmen 67:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "daß man auf Erden dein Walten erkenne, unter allen Heidenvölkern dein Heil!",
      "citation": "Psalmen 67:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Preisen müssen dich, Gott, die Völker, preisen die Völker allesamt;",
      "citation": "Psalmen 67:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "sich freuen müssen die Völkerschaften und jubeln, weil du die Völker gerecht richtest und leitest die Völkerschaften auf Erden. SELA.",
      "citation": "Psalmen 67:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Preisen müssen dich, Gott, die Völker, preisen die Völker allesamt!",
      "citation": "Psalmen 67:6 (Menge)"
    },
    {
      "verse": 7,
      "text": "Das Land hat seinen Ertrag gespendet: gesegnet hat uns Gott, unser Gott.",
      "citation": "Psalmen 67:7 (Menge)"
    },
    {
      "verse": 8,
      "text": "Es segne uns Gott, und fürchten müssen ihn alle Enden der Erde!",
      "citation": "Psalmen 67:8 (Menge)"
    }
  ]
