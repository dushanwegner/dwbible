  "verses": [
    {
      "verse": 1,
      "text": "<em>Ein Wallfahrtslied</em> <em>Davids.</em> HERR, mein Herz ist nicht hochfahrend, und meine Augen erheben sich nicht stolz; ich gehe nicht mit Dingen um, die vermessen sind und mir zu hoch.",
      "citation": "Psalmen 131:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Nein, ich habe mein Herz beruhigt und gestillt; wie ein entwöhntes Kind an der Mutter Brust, so ruht entwöhnt mein Herz in mir. –",
      "citation": "Psalmen 131:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Israel, harre des HERRN von nun an bis in Ewigkeit.",
      "citation": "Psalmen 131:3 (Menge)"
    }
  ]
