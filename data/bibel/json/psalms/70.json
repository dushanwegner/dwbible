  "citation": "Psalmen 70 (Menge)",
  "verses": [
    {
      "verse": 1,
      "text": "<em>Dem Musikmeister, von David; bei Darbringung des Duftopfers</em>.",
      "citation": "Psalmen 70:1 (Menge)"
    },
    {
      "verse": 2,
      "text": "Gott, eile zu meiner Rettung, HERR, eile zu meiner Hilfe herbei!",
      "citation": "Psalmen 70:2 (Menge)"
    },
    {
      "verse": 3,
      "text": "Laß alle beschämt und schamrot werden, die nach dem Leben mir stehn (um es auszutilgen)! Laß mit Schande beladen abziehn, die mein Unglück wünschen!",
      "citation": "Psalmen 70:3 (Menge)"
    },
    {
      "verse": 4,
      "text": "Laß zurück sich wenden ob ihrer Schmach, die über mich rufen: »Haha, haha!«",
      "citation": "Psalmen 70:4 (Menge)"
    },
    {
      "verse": 5,
      "text": "Laß jubeln und deiner sich freuen alle, die dich suchen! Laß alle, die nach deinem Heil verlangen, immerdar bekennen: »Groß ist Gott!«",
      "citation": "Psalmen 70:5 (Menge)"
    },
    {
      "verse": 6,
      "text": "Doch ich bin elend und arm: o Gott, eile zu mir! Meine Hilfe und mein Retter bist du: o HERR, säume nicht!",
      "citation": "Psalmen 70:6 (Menge)"
    }
  ]
}
