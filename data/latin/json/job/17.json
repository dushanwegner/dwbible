  "citation": "Job 17 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "spiritus meus adtenuabitur dies mei breviabuntur et solum mihi superest sepulchrum",
      "citation": "Job 17:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "non peccavi et in amaritudinibus moratur oculus meus",
      "citation": "Job 17:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "libera me et pone iuxta te et cuiusvis manus pugnet contra me",
      "citation": "Job 17:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "cor eorum longe fecisti a disciplina et propterea non exaltabuntur",
      "citation": "Job 17:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "praedam pollicetur sociis et oculi filiorum eius deficient",
      "citation": "Job 17:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "posuit me quasi in proverbium vulgi et exemplum sum coram eis",
      "citation": "Job 17:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "caligavit ab indignatione oculus meus et membra mea quasi in nihili redacta sunt",
      "citation": "Job 17:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "stupebunt iusti super hoc et innocens contra hypocritam suscitabitur",
      "citation": "Job 17:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "et tenebit iustus viam suam et mundis manibus addet fortitudinem",
      "citation": "Job 17:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "igitur vos omnes convertimini et venite et non inveniam in vobis ullum sapientem",
      "citation": "Job 17:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "dies mei transierunt cogitationes meae dissipatae sunt torquentes cor meum",
      "citation": "Job 17:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "noctem verterunt in diem et rursum post tenebras spero lucem",
      "citation": "Job 17:12 (Clementine Vulgate)"
    },
    {
      "verse": 13,
      "text": "si sustinuero infernus domus mea est in tenebris stravi lectulum meum",
      "citation": "Job 17:13 (Clementine Vulgate)"
    },
    {
      "verse": 14,
      "text": "putredini dixi pater meus es mater mea et soror mea vermibus",
      "citation": "Job 17:14 (Clementine Vulgate)"
    },
    {
      "verse": 15,
      "text": "ubi est ergo nunc praestolatio mea et patientiam meam quis considerat",
      "citation": "Job 17:15 (Clementine Vulgate)"
    },
    {
      "verse": 16,
      "text": "in profundissimum infernum descendent omnia mea putasne saltim ibi erit requies mihi",
      "citation": "Job 17:16 (Clementine Vulgate)"
    }
  ]
