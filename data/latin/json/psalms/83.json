  "citation": "Psalms 83 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "Deus quis similis erit tibi ne taceas neque conpescaris Deus",
      "citation": "Psalms 83:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem pro torcularibus filiis Core psalmus",
      "citation": "Psalms 83:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "quoniam ecce inimici tui sonaverunt et qui oderunt te extulerunt caput",
      "citation": "Psalms 83:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "super populum tuum malignaverunt consilium et cogitaverunt adversus sanctos tuos",
      "citation": "Psalms 83:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "dixerunt venite et disperdamus eos de gente et non memoretur nomen Israhel ultra",
      "citation": "Psalms 83:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "quoniam cogitaverunt unianimiter simul adversum te testamentum disposuerunt",
      "citation": "Psalms 83:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "tabernacula Idumeorum et Ismahelitae Moab et Aggareni",
      "citation": "Psalms 83:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "Gebal et Ammon et Amalech alienigenae cum habitantibus Tyrum",
      "citation": "Psalms 83:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "etenim Assur venit cum illis facti sunt in adiutorium filiis Loth diapsalma",
      "citation": "Psalms 83:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "fac illis sicut Madiam et Sisarae sicut Iabin in torrente Cison",
      "citation": "Psalms 83:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "disperierunt in Endor facti sunt ut stercus terrae",
      "citation": "Psalms 83:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "pone principes eorum sicut Oreb et Zeb et Zebee et Salmana omnes principes eorum",
      "citation": "Psalms 83:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "qui dixerunt hereditate possideamus sanctuarium Dei",
      "citation": "Psalms 83:12 (Clementine Vulgate)"
    },
    {
      "verse": 13,
      "text": "Deus meus pone illos ut rotam sicut stipulam ante faciem venti",
      "citation": "Psalms 83:13 (Clementine Vulgate)"
    },
    {
      "verse": 14,
      "text": "sicut ignis qui conburit silvam sicut flamma conburens montes",
      "citation": "Psalms 83:14 (Clementine Vulgate)"
    },
    {
      "verse": 15,
      "text": "ita persequeris illos in tempestate tua et in ira tua turbabis eos",
      "citation": "Psalms 83:15 (Clementine Vulgate)"
    },
    {
      "verse": 16,
      "text": "imple facies illorum ignominia et quaerent nomen tuum Domine",
      "citation": "Psalms 83:16 (Clementine Vulgate)"
    },
    {
      "verse": 17,
      "text": "erubescant et conturbentur in saeculum saeculi et confundantur et pereant",
      "citation": "Psalms 83:17 (Clementine Vulgate)"
    },
    {
      "verse": 18,
      "text": "et cognoscant quia nomen tibi Dominus tu solus Altissimus in omni terra",
      "citation": "Psalms 83:18 (Clementine Vulgate)"
    }
  ]
}
