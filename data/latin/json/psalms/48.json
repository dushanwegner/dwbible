  "citation": "Psalms 48 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "magnus Dominus et laudabilis nimis in civitate Dei nostri in monte sancto eius",
      "citation": "Psalms 48:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem filiis Core psalmus",
      "citation": "Psalms 48:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "fundatur exultatione universae terrae montes Sion latera aquilonis civitas regis magni",
      "citation": "Psalms 48:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "Deus in domibus eius cognoscitur cum suscipiet eam",
      "citation": "Psalms 48:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "quoniam ecce reges congregati sunt convenerunt in unum",
      "citation": "Psalms 48:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "ipsi videntes sic admirati sunt conturbati sunt commoti sunt",
      "citation": "Psalms 48:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "tremor adprehendit eos ibi dolores ut parturientis",
      "citation": "Psalms 48:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "in spiritu vehementi conteres naves Tharsis",
      "citation": "Psalms 48:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "sicut audivimus sic vidimus in civitate Domini virtutum in civitate Dei nostri Deus fundavit eam in aeternum diapsalma",
      "citation": "Psalms 48:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "suscepimus Deus misericordiam tuam in medio templi tui",
      "citation": "Psalms 48:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "secundum nomen tuum Deus sic et laus tua in fines terrae iustitia plena est dextera tua",
      "citation": "Psalms 48:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "laetetur mons Sion exultent filiae Iudaeae propter iudicia tua",
      "citation": "Psalms 48:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "circumdate Sion et conplectimini eam narrate in turribus eius",
      "citation": "Psalms 48:12 (Clementine Vulgate)"
    },
    {
      "verse": 13,
      "text": "ponite corda vestra in virtute eius et distribuite domus eius ut enarretis in progeniem alteram",
      "citation": "Psalms 48:13 (Clementine Vulgate)"
    },
    {
      "verse": 14,
      "text": "quoniam hic est Deus Deus noster in aeternum et in saeculum saeculi ipse reget nos in saecula",
      "citation": "Psalms 48:14 (Clementine Vulgate)"
    }
  ]
