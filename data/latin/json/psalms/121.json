  "citation": "Psalms 121 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum levavi oculos meos in montes unde veniet auxilium mihi",
      "citation": "Psalms 121:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "auxilium meum a Domino qui fecit caelum et terram",
      "citation": "Psalms 121:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "non det in commotionem pedem tuum neque dormitet qui custodit te",
      "citation": "Psalms 121:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "ecce non dormitabit neque dormiet qui custodit Israhel",
      "citation": "Psalms 121:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "Dominus custodit te Dominus protectio tua super manum dexteram tuam",
      "citation": "Psalms 121:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "per diem sol non uret te neque luna per noctem",
      "citation": "Psalms 121:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "Dominus custodit te ab omni malo custodiat animam tuam Dominus",
      "citation": "Psalms 121:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "Dominus custodiat introitum tuum et exitum tuum ex hoc nunc et usque in saeculum",
      "citation": "Psalms 121:8 (Clementine Vulgate)"
    }
  ]
