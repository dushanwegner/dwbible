  "citation": "Psalms 95 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "laus cantici David venite exultemus Domino iubilemus Deo salutari nostro",
      "citation": "Psalms 95:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "praeoccupemus faciem eius in confessione et in psalmis iubilemus ei",
      "citation": "Psalms 95:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "quoniam Deus magnus Dominus et rex magnus super omnes deos",
      "citation": "Psalms 95:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "quia in manu eius fines terrae et altitudines montium ipsius sunt",
      "citation": "Psalms 95:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "quoniam ipsius est mare et ipse fecit illud et siccam manus eius formaverunt",
      "citation": "Psalms 95:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "venite adoremus et procidamus et ploremus ante Dominum qui fecit nos",
      "citation": "Psalms 95:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "quia ipse est Deus noster et nos populus pascuae eius et oves manus eius",
      "citation": "Psalms 95:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "hodie si vocem eius audieritis nolite obdurare corda vestra",
      "citation": "Psalms 95:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "sicut in inritatione secundum diem temptationis in deserto ubi temptaverunt me patres vestri probaverunt *me; et viderunt opera mea",
      "citation": "Psalms 95:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "quadraginta annis offensus fui generationi illi et dixi semper errant corde",
      "citation": "Psalms 95:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "et isti non cognoverunt vias meas ut iuravi in ira mea si intrabunt in requiem meam",
      "citation": "Psalms 95:11 (Clementine Vulgate)"
    }
  ]
