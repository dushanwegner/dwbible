  "citation": "Psalms 12 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "salvum me fac Domine quoniam defecit sanctus quoniam deminutae sunt veritates a filiis hominum",
      "citation": "Psalms 12:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem psalmus David usquequo Domine oblivisceris me in finem usquequo avertis faciem tuam a me",
      "citation": "Psalms 12:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "vana locuti sunt unusquisque ad proximum suum labia dolosa in corde et corde locuti sunt",
      "citation": "Psalms 12:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "disperdat Dominus universa labia dolosa linguam magniloquam",
      "citation": "Psalms 12:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "qui dixerunt linguam nostram magnificabimus labia nostra a nobis sunt quis noster dominus est",
      "citation": "Psalms 12:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "propter miseriam inopum et gemitum pauperum nunc exsurgam dicit Dominus ponam in salutari fiducialiter agam in eo",
      "citation": "Psalms 12:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "eloquia Domini eloquia casta argentum igne examinatum probatum terrae purgatum septuplum",
      "citation": "Psalms 12:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "tu Domine servabis nos et custodies nos a generatione hac et in aeternum",
      "citation": "Psalms 12:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "in circuitu impii ambulant secundum altitudinem tuam multiplicasti filios hominum",
      "citation": "Psalms 12:8 (Clementine Vulgate)"
    }
  ]
