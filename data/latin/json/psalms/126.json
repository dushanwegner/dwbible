  "citation": "Psalms 126 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum in convertendo Dominum captivitatem Sion facti sumus sicut consolati",
      "citation": "Psalms 126:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "tunc repletum est gaudio os nostrum et lingua nostra exultatione tunc dicent inter gentes magnificavit Dominus facere cum eis",
      "citation": "Psalms 126:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "magnificavit Dominus facere nobiscum facti sumus laetantes",
      "citation": "Psalms 126:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "converte Domine captivitatem nostram sicut torrens in austro",
      "citation": "Psalms 126:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "qui seminant in lacrimis in exultatione metent",
      "citation": "Psalms 126:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "euntes ibant et flebant portantes semina sua venientes autem venient in exultatione portantes manipulos suos",
      "citation": "Psalms 126:6 (Clementine Vulgate)"
    }
  ]
