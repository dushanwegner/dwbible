  "citation": "Psalms 64 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "exaudi Deus orationem meam cum deprecor a timore inimici eripe animam meam",
      "citation": "Psalms 64:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem psalmus David *canticum; Hieremiae et Aggei de verbo peregrinationis quando incipiebant proficisci",
      "citation": "Psalms 64:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "protexisti me a conventu malignantium a multitudine operantium iniquitatem",
      "citation": "Psalms 64:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "quia exacuerunt ut gladium linguas suas intenderunt arcum rem amaram",
      "citation": "Psalms 64:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "ut sagittent in occultis inmaculatum",
      "citation": "Psalms 64:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "subito sagittabunt eum et non timebunt firmaverunt sibi sermonem nequam narraverunt ut absconderent laqueos dixerunt quis videbit eos",
      "citation": "Psalms 64:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "scrutati sunt iniquitates defecerunt scrutantes scrutinio accedet homo et cor altum",
      "citation": "Psalms 64:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "et exaltabitur Deus sagittae parvulorum factae sunt plagae eorum",
      "citation": "Psalms 64:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "et infirmatae sunt contra eos linguae eorum conturbati sunt omnes qui videbant eos",
      "citation": "Psalms 64:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "et timuit omnis homo et adnuntiaverunt opera Dei et facta eius intellexerunt",
      "citation": "Psalms 64:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "laetabitur iustus in Domino et sperabit in eo et laudabuntur omnes recti corde",
      "citation": "Psalms 64:10 (Clementine Vulgate)"
    }
  ]
