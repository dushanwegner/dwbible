  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum David Domine non est exaltatum cor meum neque elati sunt oculi mei neque ambulavi in magnis neque in mirabilibus super me",
      "citation": "Psalms 131:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "si non humiliter sentiebam sed exaltavi animam meam sicut ablactatum super matrem suam ita retributio in anima mea",
      "citation": "Psalms 131:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "speret Israhel in Domino ex hoc nunc et usque in saeculum",
      "citation": "Psalms 131:3 (Clementine Vulgate)"
    }
