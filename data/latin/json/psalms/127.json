  "citation": "Psalms 127 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum Salomonis nisi Dominus aedificaverit domum in vanum laboraverunt qui aedificant eam nisi Dominus custodierit civitatem frustra vigilavit qui custodit",
      "citation": "Psalms 127:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "vanum est vobis ante lucem surgere surgere postquam sederitis qui manducatis panem doloris cum dederit dilectis suis somnum",
      "citation": "Psalms 127:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "ecce hereditas Domini filii mercis fructus ventris",
      "citation": "Psalms 127:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "sicut sagittae in manu potentis ita filii excussorum",
      "citation": "Psalms 127:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "beatus vir qui implebit desiderium suum ex ipsis non confundentur cum loquentur inimicis suis in porta",
      "citation": "Psalms 127:5 (Clementine Vulgate)"
    }
  ]
