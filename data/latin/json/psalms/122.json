  "citation": "Psalms 122 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum huic David laetatus sum in his quae dicta sunt mihi in domum Domini ibimus",
      "citation": "Psalms 122:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "stantes erant pedes nostri in atriis tuis Hierusalem",
      "citation": "Psalms 122:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "Hierusalem quae aedificatur ut civitas cuius participatio eius in id ipsum",
      "citation": "Psalms 122:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "illic enim ascenderunt tribus tribus Domini testimonium Israhel ad confitendum nomini Domini",
      "citation": "Psalms 122:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "quia illic sederunt sedes in iudicium sedes super domum David",
      "citation": "Psalms 122:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "rogate quae ad pacem sunt Hierusalem et abundantia diligentibus te",
      "citation": "Psalms 122:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "fiat pax in virtute tua et abundantia in turribus tuis",
      "citation": "Psalms 122:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "propter fratres meos et proximos meos loquebar pacem de te",
      "citation": "Psalms 122:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "propter domum Domini Dei nostri quaesivi bona tibi",
      "citation": "Psalms 122:9 (Clementine Vulgate)"
    }
  ]
