  "citation": "Psalms 76 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "notus in Iudaea Deus in Israhel magnum nomen eius",
      "citation": "Psalms 76:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem pro Idithun psalmus Asaph",
      "citation": "Psalms 76:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "et factus est in pace locus eius et habitatio eius in Sion",
      "citation": "Psalms 76:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "ibi confregit potentias arcuum scutum et gladium et bellum diapsalma",
      "citation": "Psalms 76:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "inluminas tu mirabiliter de montibus aeternis",
      "citation": "Psalms 76:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "turbati sunt omnes insipientes corde dormierunt somnum suum et nihil invenerunt omnes viri divitiarum manibus suis",
      "citation": "Psalms 76:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "ab increpatione tua Deus Iacob dormitaverunt qui ascenderunt equos",
      "citation": "Psalms 76:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "tu terribilis es et quis resistet tibi ex tunc ira tua",
      "citation": "Psalms 76:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "de caelo auditum fecisti iudicium terra timuit et quievit",
      "citation": "Psalms 76:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "cum exsurgeret in iudicium Deus ut salvos faceret omnes mansuetos terrae diapsalma",
      "citation": "Psalms 76:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "quoniam cogitatio hominis confitebitur tibi et reliquiae cogitationis diem festum agent tibi",
      "citation": "Psalms 76:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "vovete et reddite Domino Deo vestro omnes qui in circuitu eius adferent munera terribili",
      "citation": "Psalms 76:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "et ei qui aufert spiritus principum terribili apud reges terrae",
      "citation": "Psalms 76:12 (Clementine Vulgate)"
    }
  ]
