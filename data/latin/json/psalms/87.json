  "citation": "Psalms 87 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "filiis Core psalmus cantici fundamenta eius in montibus sanctis",
      "citation": "Psalms 87:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "canticum psalmi filiis Core in finem pro Maeleth ad respondendum intellectus Eman Ezraitae",
      "citation": "Psalms 87:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "diligit Dominus portas Sion super omnia tabernacula Iacob",
      "citation": "Psalms 87:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "gloriosa dicta sunt de te civitas Dei diapsalma",
      "citation": "Psalms 87:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "memor ero Raab et Babylonis scientibus me ecce alienigenae et Tyrus et populus Aethiopum hii fuerunt illic",
      "citation": "Psalms 87:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "numquid Sion dicet homo et homo natus est in ea et ipse fundavit eam Altissimus",
      "citation": "Psalms 87:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "Dominus narrabit in scriptura populorum et principum horum qui fuerunt in ea diapsalma",
      "citation": "Psalms 87:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "sicut laetantium omnium habitatio in te",
      "citation": "Psalms 87:7 (Clementine Vulgate)"
    }
  ]
