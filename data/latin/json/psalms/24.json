  "citation": "Psalms 24 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "psalmus David prima sabbati Domini est terra et plenitudo eius orbis terrarum et qui habitant in eo",
      "citation": "Psalms 24:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "*quia; ipse super maria fundavit eum et super flumina praeparavit eum",
      "citation": "Psalms 24:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "quis ascendit in montem Domini aut quis stabit in loco sancto eius",
      "citation": "Psalms 24:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "innocens manibus et mundo corde qui non accepit in vano animam suam nec iuravit in dolo proximo suo",
      "citation": "Psalms 24:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "hic accipiet benedictionem a Domino et misericordiam a Deo salvatore suo",
      "citation": "Psalms 24:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "haec est generatio quaerentium eum quaerentium faciem Dei Iacob diapsalma",
      "citation": "Psalms 24:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "adtollite portas principes vestras et elevamini portae aeternales et introibit rex gloriae",
      "citation": "Psalms 24:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "quis est iste rex gloriae Dominus fortis et potens Dominus potens in proelio",
      "citation": "Psalms 24:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "adtollite portas principes vestras et elevamini portae aeternales et introibit rex gloriae",
      "citation": "Psalms 24:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "quis est iste rex gloriae Dominus virtutum ipse est rex gloriae diapsalma",
      "citation": "Psalms 24:10 (Clementine Vulgate)"
    }
