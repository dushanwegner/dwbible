  "citation": "Psalms 129 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum saepe expugnaverunt me a iuventute mea dicat nunc Israhel",
      "citation": "Psalms 129:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "saepe expugnaverunt me a iuventute mea etenim non potuerunt mihi",
      "citation": "Psalms 129:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "supra dorsum meum fabricabantur peccatores prolongaverunt iniquitatem suam",
      "citation": "Psalms 129:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "Dominus iustus concidet cervices peccatorum",
      "citation": "Psalms 129:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "confundantur et convertantur retrorsum omnes qui oderunt Sion",
      "citation": "Psalms 129:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "fiant sicut faenum tectorum quod priusquam evellatur exaruit",
      "citation": "Psalms 129:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "de quo non implevit manum suam qui metit et sinum suum qui manipulos colligit",
      "citation": "Psalms 129:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "et non dixerunt qui praeteribant benedictio Domini super vos benediximus vobis in nomine Domini",
      "citation": "Psalms 129:8 (Clementine Vulgate)"
    }
  ]
