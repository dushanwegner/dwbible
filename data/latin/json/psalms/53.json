  "citation": "Psalms 53 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "corrupti sunt et abominabiles facti sunt in iniquitatibus non est qui faciat bonum",
      "citation": "Psalms 53:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "Deus de caelo prospexit in filios hominum ut videat si est intellegens requirens Deum",
      "citation": "Psalms 53:2 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "cum venissent Ziphei et dixissent ad Saul nonne David absconditus est apud nos",
      "citation": "Psalms 53:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "omnes declinaverunt simul inutiles facti sunt non est qui faciat bonum non est usque ad unum",
      "citation": "Psalms 53:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "nonne scient qui operantur iniquitatem qui devorant plebem meam ut cibum panis",
      "citation": "Psalms 53:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "Deum non invocaverunt illic trepidabunt timore ubi non fuit timor quoniam Deus dissipavit ossa eorum qui hominibus placent confusi sunt quoniam Deus sprevit eos",
      "citation": "Psalms 53:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "quis dabit ex Sion salutare Israhel dum convertit Deus captivitatem plebis suae exultabit Iacob et laetabitur Israhel",
      "citation": "Psalms 53:6 (Clementine Vulgate)"
    }
  ]
