  "citation": "Psalms 52 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "in finem intellectus David",
      "citation": "Psalms 52:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "quid gloriatur in malitia qui potens est iniquitate",
      "citation": "Psalms 52:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem pro Melech intellegentiae David dixit insipiens in corde suo non est Deus",
      "citation": "Psalms 52:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "tota die iniustitiam cogitavit lingua tua sicut novacula acuta fecisti dolum",
      "citation": "Psalms 52:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "dilexisti malitiam super benignitatem iniquitatem magis quam loqui aequitatem diapsalma",
      "citation": "Psalms 52:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "dilexisti omnia verba praecipitationis linguam dolosam",
      "citation": "Psalms 52:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "propterea Deus destruet te in finem evellet te et emigrabit te de tabernaculo et radicem tuam de terra viventium diapsalma",
      "citation": "Psalms 52:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "videbunt iusti et timebunt et super eum ridebunt et dicent",
      "citation": "Psalms 52:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "ecce homo qui non posuit Deum adiutorem suum sed speravit in multitudine divitiarum suarum et praevaluit in vanitate sua",
      "citation": "Psalms 52:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "ego autem sicut oliva fructifera in domo Dei speravi in misericordia Dei in aeternum et in saeculum saeculi",
      "citation": "Psalms 52:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "confitebor tibi in saeculum quia fecisti et expectabo nomen tuum quoniam bonum in conspectu sanctorum tuorum",
      "citation": "Psalms 52:9 (Clementine Vulgate)"
    }
  ]
