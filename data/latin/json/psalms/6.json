  "citation": "Psalms 6 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "in finem in carminibus pro octava psalmus David",
      "citation": "Psalms 6:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "Domine ne in furore tuo arguas me neque in ira tua corripias me",
      "citation": "Psalms 6:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "miserere mei Domine quoniam infirmus sum sana me Domine quoniam conturbata sunt ossa mea",
      "citation": "Psalms 6:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "et anima mea turbata est valde et tu Domine usquequo",
      "citation": "Psalms 6:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "convertere Domine eripe animam meam salvum me fac propter misericordiam tuam",
      "citation": "Psalms 6:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "quoniam non est in morte qui memor sit tui in inferno autem quis confitebitur tibi",
      "citation": "Psalms 6:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "laboravi in gemitu meo lavabo per singulas noctes lectum meum in lacrimis meis stratum meum rigabo",
      "citation": "Psalms 6:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "turbatus est a furore oculus meus inveteravi inter omnes inimicos meos",
      "citation": "Psalms 6:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "discedite a me omnes qui operamini iniquitatem quoniam exaudivit Dominus vocem fletus mei",
      "citation": "Psalms 6:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "exaudivit Dominus deprecationem meam Dominus orationem meam suscepit",
      "citation": "Psalms 6:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "erubescant et conturbentur vehementer omnes inimici mei convertantur et erubescant valde velociter",
      "citation": "Psalms 6:11 (Clementine Vulgate)"
    }
  ]
