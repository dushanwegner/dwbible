  "citation": "Psalms 82 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "psalmus Asaph Deus stetit in synagoga deorum in medio autem Deus deiudicat",
      "citation": "Psalms 82:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "canticum psalmi Asaph",
      "citation": "Psalms 82:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "usquequo iudicatis iniquitatem et facies peccatorum sumitis diapsalma",
      "citation": "Psalms 82:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "iudicate egenum et pupillum humilem et pauperem iustificate",
      "citation": "Psalms 82:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "eripite pauperem et egenum de manu peccatoris liberate",
      "citation": "Psalms 82:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "nescierunt neque intellexerunt in tenebris ambulant movebuntur omnia fundamenta terrae",
      "citation": "Psalms 82:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "ego dixi dii estis et filii Excelsi omnes",
      "citation": "Psalms 82:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "vos autem sicut homines moriemini et sicut unus de principibus cadetis",
      "citation": "Psalms 82:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "surge Deus iudica terram quoniam tu hereditabis in omnibus gentibus",
      "citation": "Psalms 82:8 (Clementine Vulgate)"
    }
  ]
