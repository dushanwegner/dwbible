  "citation": "Psalms 23 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "psalmus David Dominus reget me et nihil mihi deerit",
      "citation": "Psalms 23:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "in loco pascuae me conlocavit super aquam refectionis educavit me",
      "citation": "Psalms 23:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "animam meam convertit deduxit me super semitas iustitiae propter nomen suum",
      "citation": "Psalms 23:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "nam et si ambulavero in medio umbrae mortis non timebo mala quoniam tu mecum es virga tua et baculus tuus ipsa me consolata sunt",
      "citation": "Psalms 23:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "parasti in conspectu meo mensam adversus eos qui tribulant me inpinguasti in oleo caput meum et calix meus inebrians quam praeclarus est",
      "citation": "Psalms 23:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "et misericordia tua subsequitur me omnibus diebus vitae meae et ut inhabitem in domo Domini in longitudinem dierum",
      "citation": "Psalms 23:6 (Clementine Vulgate)"
    }
  ]
