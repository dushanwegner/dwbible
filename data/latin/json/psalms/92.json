  "citation": "Psalms 92 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "bonum est confiteri Domino et psallere nomini tuo Altissime",
      "citation": "Psalms 92:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "ad adnuntiandum mane misericordiam tuam et veritatem tuam per noctem",
      "citation": "Psalms 92:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "in decacordo psalterio cum cantico in cithara",
      "citation": "Psalms 92:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "quia delectasti me Domine in factura tua et in operibus manuum tuarum exultabo",
      "citation": "Psalms 92:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "quam magnificata sunt opera tua Domine nimis profundae factae sunt cogitationes tuae",
      "citation": "Psalms 92:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "vir insipiens non cognoscet et stultus non intelleget haec",
      "citation": "Psalms 92:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "cum exorti fuerint peccatores sicut faenum et apparuerint omnes qui operantur iniquitatem ut intereant in saeculum",
      "citation": "Psalms 92:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "tu autem Altissimus in aeternum Domine",
      "citation": "Psalms 92:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "*quoniam ecce inimici tui Domine; quoniam ecce inimici tui peribunt et dispergentur omnes qui operantur iniquitatem",
      "citation": "Psalms 92:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "et exaltabitur sicut unicornis cornu meum et senectus mea in misericordia uberi",
      "citation": "Psalms 92:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "et despexit oculus meus inimicis meis et insurgentibus in me malignantibus audiet auris mea",
      "citation": "Psalms 92:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "iustus ut palma florebit ut cedrus Libani multiplicabitur",
      "citation": "Psalms 92:12 (Clementine Vulgate)"
    },
    {
      "verse": 13,
      "text": "plantati in domo Domini in atriis Dei nostri florebunt",
      "citation": "Psalms 92:13 (Clementine Vulgate)"
    },
    {
      "verse": 14,
      "text": "adhuc multiplicabuntur in senecta uberi et bene patientes erunt",
      "citation": "Psalms 92:14 (Clementine Vulgate)"
    },
    {
      "verse": 15,
      "text": "ut adnuntient quoniam rectus Dominus Deus noster et non est iniquitas in eo",
      "citation": "Psalms 92:15 (Clementine Vulgate)"
    }
  ]
