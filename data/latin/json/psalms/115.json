  "citation": "Psalms 115 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "non nobis Domine non nobis sed nomini tuo da gloriam",
      "citation": "Psalms 115:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "super misericordia tua et veritate tua nequando dicant gentes ubi est Deus eorum",
      "citation": "Psalms 115:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "Deus autem noster in caelo omnia quaecumque voluit fecit",
      "citation": "Psalms 115:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "simulacra gentium argentum et aurum opera manuum hominum",
      "citation": "Psalms 115:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "os habent et non loquentur oculos habent et non videbunt",
      "citation": "Psalms 115:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "aures habent et non audient nares habent et non odorabuntur",
      "citation": "Psalms 115:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "manus habent et non palpabunt pedes habent et non ambulabunt non clamabunt in gutture suo",
      "citation": "Psalms 115:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "similes illis fiant qui faciunt ea et omnes qui confidunt in eis",
      "citation": "Psalms 115:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "domus Israhel speravit in Domino adiutor eorum et protector eorum est",
      "citation": "Psalms 115:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "domus Aaron speravit in Domino adiutor eorum et protector eorum est",
      "citation": "Psalms 115:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "qui timent Dominum speraverunt in Domino adiutor eorum et protector eorum est",
      "citation": "Psalms 115:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "Dominus memor fuit nostri et benedixit nobis benedixit domui Israhel benedixit domui Aaron",
      "citation": "Psalms 115:12 (Clementine Vulgate)"
    },
    {
      "verse": 13,
      "text": "benedixit omnibus qui timent Dominum pusillis cum maioribus",
      "citation": "Psalms 115:13 (Clementine Vulgate)"
    },
    {
      "verse": 14,
      "text": "adiciat Dominus super vos super vos et super filios vestros",
      "citation": "Psalms 115:14 (Clementine Vulgate)"
    },
    {
      "verse": 15,
      "text": "benedicti vos Domino qui fecit caelum et terram",
      "citation": "Psalms 115:15 (Clementine Vulgate)"
    },
    {
      "verse": 16,
      "text": "caelum caeli Domino terram autem dedit filiis hominum",
      "citation": "Psalms 115:16 (Clementine Vulgate)"
    },
    {
      "verse": 17,
      "text": "non mortui laudabunt te Domine neque omnes qui descendunt in infernum",
      "citation": "Psalms 115:17 (Clementine Vulgate)"
    },
    {
      "verse": 18,
      "text": "sed nos qui vivimus benedicimus Domino ex hoc nunc et usque in saeculum",
      "citation": "Psalms 115:18 (Clementine Vulgate)"
    }
  ]
}
