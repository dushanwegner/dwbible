  "citation": "Psalms 26 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "psalmus David iudica me Domine quoniam ego in innocentia mea ingressus sum et in Domino sperans non infirmabor",
      "citation": "Psalms 26:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "proba me Domine et tempta me ure renes meos et cor meum",
      "citation": "Psalms 26:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "quoniam misericordia tua ante oculos meos est et conplacui in veritate tua",
      "citation": "Psalms 26:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "non sedi cum concilio vanitatis et cum iniqua gerentibus non introibo",
      "citation": "Psalms 26:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "odivi ecclesiam malignantium et cum impiis non sedebo",
      "citation": "Psalms 26:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "lavabo inter innocentes manus meas et circumdabo altare tuum Domine",
      "citation": "Psalms 26:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "ut audiam vocem laudis et enarrem universa mirabilia tua",
      "citation": "Psalms 26:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "Domine dilexi decorem domus tuae et locum habitationis gloriae tuae",
      "citation": "Psalms 26:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "ne perdas cum impiis animam meam et cum viris sanguinum vitam meam",
      "citation": "Psalms 26:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "in quorum manibus iniquitates sunt dextera eorum repleta est muneribus",
      "citation": "Psalms 26:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "ego autem in innocentia mea ingressus sum redime me et miserere mei",
      "citation": "Psalms 26:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "pes meus stetit in directo in ecclesiis benedicam Domine",
      "citation": "Psalms 26:12 (Clementine Vulgate)"
    }
  ]
