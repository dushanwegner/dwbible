  "citation": "Psalms 29 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "psalmus David in consummatione tabernaculi adferte Domino filii Dei adferte Domino filios arietum",
      "citation": "Psalms 29:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "psalmus cantici in dedicatione domus David",
      "citation": "Psalms 29:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "adferte Domino gloriam et honorem adferte Domino gloriam nomini eius adorate Dominum in atrio sancto eius",
      "citation": "Psalms 29:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "vox Domini super aquas Deus maiestatis intonuit Dominus super aquas multas",
      "citation": "Psalms 29:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "vox Domini in virtute vox Domini in magnificentia",
      "citation": "Psalms 29:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "vox Domini confringentis cedros et confringet Dominus cedros Libani",
      "citation": "Psalms 29:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "et comminuet eas tamquam vitulum Libani et dilectus quemadmodum filius unicornium",
      "citation": "Psalms 29:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "vox Domini intercidentis flammam ignis",
      "citation": "Psalms 29:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "vox Domini concutientis desertum et commovebit Dominus desertum Cades",
      "citation": "Psalms 29:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "vox Domini praeparantis cervos et revelabit condensa et in templo eius omnis dicet gloriam",
      "citation": "Psalms 29:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "Dominus diluvium inhabitare facit et sedebit Dominus rex in aeternum",
      "citation": "Psalms 29:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "Dominus virtutem populo suo dabit Dominus benedicet populo suo in pace",
      "citation": "Psalms 29:11 (Clementine Vulgate)"
    }
  ]
