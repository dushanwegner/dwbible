  "citation": "Psalms 63 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "Deus Deus meus ad te de luce vigilo sitivit in te anima mea quam multipliciter tibi caro mea",
      "citation": "Psalms 63:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem psalmus David",
      "citation": "Psalms 63:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "in terra deserta et invia et inaquosa sic in sancto apparui tibi ut viderem virtutem tuam et gloriam tuam",
      "citation": "Psalms 63:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "quoniam melior est misericordia tua super vitas labia mea laudabunt te",
      "citation": "Psalms 63:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "sic benedicam te in vita mea in nomine tuo levabo manus meas",
      "citation": "Psalms 63:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "sicut adipe et pinguidine repleatur anima mea et labia exultationis laudabit os meum",
      "citation": "Psalms 63:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "si memor fui tui super stratum meum in matutinis meditabar in te",
      "citation": "Psalms 63:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "quia fuisti adiutor meus et in velamento alarum tuarum exultabo",
      "citation": "Psalms 63:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "adhesit anima mea post te me suscepit dextera tua",
      "citation": "Psalms 63:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "ipsi vero in vanum quaesierunt animam meam introibunt in inferiora terrae",
      "citation": "Psalms 63:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "tradentur in manus gladii partes vulpium erunt",
      "citation": "Psalms 63:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "rex vero laetabitur in Deo laudabitur omnis qui iurat in eo quia obstructum est os loquentium iniqua",
      "citation": "Psalms 63:11 (Clementine Vulgate)"
    }
  ]
