  "citation": "Psalms 46 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "Deus noster refugium et virtus adiutor in tribulationibus quae invenerunt nos nimis",
      "citation": "Psalms 46:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem pro filiis Core psalmus",
      "citation": "Psalms 46:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "propterea non timebimus dum turbabitur terra et transferentur montes in cor maris",
      "citation": "Psalms 46:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "sonaverunt et turbatae sunt aquae eorum conturbati sunt montes in fortitudine eius diapsalma",
      "citation": "Psalms 46:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "fluminis impetus laetificat civitatem Dei sanctificavit tabernaculum suum Altissimus",
      "citation": "Psalms 46:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "Deus in medio eius non commovebitur adiuvabit eam Deus mane diluculo",
      "citation": "Psalms 46:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "conturbatae sunt gentes inclinata sunt regna dedit vocem suam mota est terra",
      "citation": "Psalms 46:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "Dominus virtutum nobiscum susceptor noster Deus Iacob diapsalma",
      "citation": "Psalms 46:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "venite et videte opera Domini quae posuit prodigia super terram",
      "citation": "Psalms 46:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "auferens bella usque ad finem terrae arcum conteret et confringet arma et scuta conburet in igne",
      "citation": "Psalms 46:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "vacate et videte quoniam ego sum Deus exaltabor in gentibus exaltabor in terra",
      "citation": "Psalms 46:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "Dominus virtutum nobiscum susceptor noster Deus Iacob",
      "citation": "Psalms 46:11 (Clementine Vulgate)"
    }
  ]
