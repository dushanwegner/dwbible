  "citation": "Psalms 2 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "psalmus David quare fremuerunt gentes et populi meditati sunt inania",
      "citation": "Psalms 2:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "adstiterunt reges terrae et principes convenerunt in unum adversus Dominum et adversus christum eius diapsalma",
      "citation": "Psalms 2:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "disrumpamus vincula eorum et proiciamus a nobis iugum ipsorum",
      "citation": "Psalms 2:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "qui habitat in caelis inridebit eos et Dominus subsannabit eos",
      "citation": "Psalms 2:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "tunc loquetur ad eos in ira sua et in furore suo conturbabit eos",
      "citation": "Psalms 2:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "ego autem constitutus sum rex ab eo super Sion montem sanctum eius praedicans praeceptum eius",
      "citation": "Psalms 2:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "Dominus dixit ad me filius meus es tu ego hodie genui te",
      "citation": "Psalms 2:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "postula a me et dabo tibi gentes hereditatem tuam et possessionem tuam terminos terrae",
      "citation": "Psalms 2:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "reges eos in virga ferrea tamquam vas figuli confringes eos",
      "citation": "Psalms 2:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "et nunc reges intellegite erudimini qui iudicatis terram",
      "citation": "Psalms 2:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "servite Domino in timore et exultate ei in tremore",
      "citation": "Psalms 2:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "adprehendite disciplinam nequando irascatur Dominus et pereatis de via iusta",
      "citation": "Psalms 2:12 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "cum exarserit in brevi ira eius beati omnes qui confidunt in eo",
      "citation": "Psalms 2:12 (Clementine Vulgate)"
    }
  ]
