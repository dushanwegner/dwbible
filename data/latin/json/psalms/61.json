  "citation": "Psalms 61 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "exaudi Deus deprecationem meam intende orationi meae",
      "citation": "Psalms 61:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem pro Idithun psalmus David",
      "citation": "Psalms 61:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "a finibus terrae ad te clamavi dum anxiaretur cor meum in petra exaltasti me deduxisti me",
      "citation": "Psalms 61:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "quia factus es spes mea turris fortitudinis a facie inimici",
      "citation": "Psalms 61:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "inhabitabo in tabernaculo tuo in saecula protegar in velamento alarum tuarum diapsalma",
      "citation": "Psalms 61:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "quoniam tu Deus meus exaudisti orationem meam dedisti hereditatem timentibus nomen tuum",
      "citation": "Psalms 61:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "dies super dies regis adicies annos eius usque in diem generationis et generationis",
      "citation": "Psalms 61:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "permanet in aeternum in conspectu Dei misericordiam et veritatem quis requiret eius",
      "citation": "Psalms 61:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "sic psalmum dicam nomini tuo in saeculum saeculi ut reddam vota mea de die in diem",
      "citation": "Psalms 61:8 (Clementine Vulgate)"
    }
  ]
