  "citation": "Psalms 110 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "David psalmus dixit Dominus Domino meo sede a dextris meis donec ponam inimicos tuos scabillum pedum tuorum",
      "citation": "Psalms 110:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "virgam virtutis tuae emittet Dominus ex Sion dominare in medio inimicorum tuorum",
      "citation": "Psalms 110:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "tecum principium in die virtutis tuae in splendoribus sanctorum ex utero ante luciferum genui te",
      "citation": "Psalms 110:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "iuravit Dominus et non paenitebit eum tu es sacerdos in aeternum secundum ordinem Melchisedech",
      "citation": "Psalms 110:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "Dominus a dextris tuis confregit in die irae suae reges",
      "citation": "Psalms 110:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "iudicabit in nationibus implebit cadavera conquassabit capita in terra multorum",
      "citation": "Psalms 110:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "de torrente in via bibet propterea exaltabit caput",
      "citation": "Psalms 110:7 (Clementine Vulgate)"
    }
  ]
}
