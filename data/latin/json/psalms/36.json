  "citation": "Psalms 36 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "dixit iniustus ut delinquat in semet ipso non est timor Dei ante oculos eius",
      "citation": "Psalms 36:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "quoniam dolose egit in conspectu eius ut inveniatur iniquitas eius ad odium",
      "citation": "Psalms 36:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "verba oris eius iniquitas et dolus noluit intellegere ut bene ageret",
      "citation": "Psalms 36:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "iniquitatem meditatus est in cubili suo adstetit omni viae non bonae malitiam autem non odivit",
      "citation": "Psalms 36:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "Domine in caelo misericordia tua et veritas tua usque ad nubes",
      "citation": "Psalms 36:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "iustitia tua sicut montes Dei iudicia tua abyssus multa homines et iumenta salvabis Domine",
      "citation": "Psalms 36:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "quemadmodum multiplicasti misericordiam tuam Deus filii autem hominum in tegmine alarum tuarum sperabunt",
      "citation": "Psalms 36:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "inebriabuntur ab ubertate domus tuae et torrente voluntatis tuae potabis eos",
      "citation": "Psalms 36:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "quoniam apud te fons vitae in lumine tuo videbimus lumen",
      "citation": "Psalms 36:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "praetende misericordiam tuam scientibus te et iustitiam tuam his qui recto sunt corde",
      "citation": "Psalms 36:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "non veniat mihi pes superbiae et manus peccatoris non moveat me",
      "citation": "Psalms 36:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "ibi ceciderunt qui operantur iniquitatem expulsi sunt nec potuerunt stare",
      "citation": "Psalms 36:12 (Clementine Vulgate)"
    }
  ]
