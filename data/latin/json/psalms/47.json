  "verses": [
    {
      "verse": 1,
      "text": "omnes gentes plaudite manibus iubilate Deo in voce exultationis",
      "citation": "Psalms 47:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "canticum psalmi filiis Core secunda sabbati",
      "citation": "Psalms 47:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "quoniam Dominus excelsus terribilis rex magnus super omnem terram",
      "citation": "Psalms 47:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "subiecit populos nobis et gentes sub pedibus nostris",
      "citation": "Psalms 47:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "elegit nobis hereditatem suam speciem Iacob quam dilexit diapsalma",
      "citation": "Psalms 47:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "ascendit Deus in iubilo Dominus in voce tubae",
      "citation": "Psalms 47:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "psallite Deo nostro psallite psallite regi nostro psallite",
      "citation": "Psalms 47:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "quoniam rex omnis terrae Deus psallite sapienter",
      "citation": "Psalms 47:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "regnavit Deus super gentes Deus sedit super sedem sanctam suam",
      "citation": "Psalms 47:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "principes populorum congregati sunt cum Deo Abraham quoniam Dei fortes terrae vehementer elevati sunt",
      "citation": "Psalms 47:9 (Clementine Vulgate)"
    }
  ]
