    },
    {
      "verse": 1,
      "text": "in Domino confido quomodo dicitis animae meae transmigra in montes sicut passer",
      "citation": "Psalms 11:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem pro octava psalmus David",
      "citation": "Psalms 11:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "quoniam ecce peccatores intenderunt arcum paraverunt sagittas suas in faretra ut sagittent in obscuro rectos corde",
      "citation": "Psalms 11:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "quoniam quae perfecisti destruxerunt iustus quid fecit",
      "citation": "Psalms 11:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "Dominus in templo sancto suo Dominus in caelo sedis eius oculi eius respiciunt palpebrae eius interrogant filios hominum",
      "citation": "Psalms 11:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "Dominus interrogat iustum et impium qui autem diligit iniquitatem odit animam suam",
      "citation": "Psalms 11:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "pluet super peccatores laqueos ignis et sulphur et spiritus procellarum pars calicis eorum",
      "citation": "Psalms 11:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "quoniam iustus Dominus iustitias dilexit aequitatem vidit vultus eius",
      "citation": "Psalms 11:7 (Clementine Vulgate)"
    }
