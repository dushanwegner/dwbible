  "citation": "Psalms 114 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "alleluia in exitu Israhel de Aegypto domus Iacob de populo barbaro",
      "citation": "Psalms 114:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "facta est Iudaea sanctificatio eius Israhel potestas eius",
      "citation": "Psalms 114:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "mare vidit et fugit Iordanis conversus est retrorsum",
      "citation": "Psalms 114:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "montes exultaverunt ut arietes colles sicut agni ovium",
      "citation": "Psalms 114:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "quid est tibi mare quod fugisti et tu Iordanis quia conversus es retrorsum",
      "citation": "Psalms 114:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "montes exultastis sicut arietes et colles sicut agni ovium",
      "citation": "Psalms 114:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "a facie Domini mota est terra a facie Dei Iacob",
      "citation": "Psalms 114:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "qui convertit petram in stagna aquarum et rupem in fontes aquarum",
      "citation": "Psalms 114:8 (Clementine Vulgate)"
    }
  ]
