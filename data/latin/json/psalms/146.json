  "citation": "Psalms 146 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "alleluia Aggei et Zacchariae",
      "citation": "Psalms 146:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "lauda anima mea Dominum laudabo Dominum in vita mea psallam Deo meo quamdiu fuero nolite confidere in principibus",
      "citation": "Psalms 146:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "in filiis hominum quibus non est salus",
      "citation": "Psalms 146:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "exibit spiritus eius et revertetur in terram suam in illa die peribunt omnes cogitationes eorum",
      "citation": "Psalms 146:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "beatus cuius Deus Iacob adiutor eius spes eius in Domino Deo ipsius",
      "citation": "Psalms 146:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "qui fecit caelum et terram mare et omnia quae in eis",
      "citation": "Psalms 146:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "qui custodit veritatem in saeculum facit iudicium iniuriam patientibus dat escam esurientibus Dominus solvit conpeditos",
      "citation": "Psalms 146:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "Dominus inluminat caecos Dominus erigit adlisos Dominus diligit iustos",
      "citation": "Psalms 146:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "Dominus custodit advenas pupillum et viduam suscipiet et viam peccatorum disperdet",
      "citation": "Psalms 146:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "regnabit Dominus in saecula Deus tuus Sion in generationem et generationem",
      "citation": "Psalms 146:10 (Clementine Vulgate)"
    }
  ]
