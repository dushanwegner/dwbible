  "verses": [
    {
      "verse": 1,
      "text": "Deus in adiutorium meum intende * Domine ad adiuvandum me festina;",
      "citation": "Psalms 70:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "Deus ut liberes me Domine ut auxilieris mihi festina",
      "citation": "Psalms 70:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "confundantur et revereantur qui quaerunt animam meam",
      "citation": "Psalms 70:2 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "confundantur et erubescant qui quaerunt animam meam",
      "citation": "Psalms 70:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "avertantur retrorsum et erubescant qui volunt mihi mala avertantur statim erubescentes qui dicunt %mihi; euge euge",
      "citation": "Psalms 70:3 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "convertantur retrorsum et erubescant qui volunt malum mihi revertantur ad vestigium confusionis suae qui dicunt va va",
      "citation": "Psalms 70:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "exultent et laetentur in te omnes qui quaerunt te et dicant semper magnificetur Deus qui diligunt salutare tuum",
      "citation": "Psalms 70:4 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "gaudeant et laetentur in te omnes qui quaerunt te et dicant semper magnificetur Deus qui diligunt salutare tuum",
      "citation": "Psalms 70:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "ego vero egenus et pauper Deus adiuva me adiutor meus et liberator meus es tu Domine ne moreris",
      "citation": "Psalms 70:5 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "ego autem egenus et pauper Deus festina pro me auxilium meum et salvator meus tu Domine ne moreris",
      "citation": "Psalms 70:5 (Clementine Vulgate)"
    }
  ]
