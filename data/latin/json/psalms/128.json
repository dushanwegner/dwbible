  "citation": "Psalms 128 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum beati omnes qui timent Dominum qui ambulant in viis eius",
      "citation": "Psalms 128:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "labores manuum tuarum *quia; manducabis beatus es et bene tibi erit",
      "citation": "Psalms 128:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "uxor tua sicut vitis abundans in lateribus domus tuae filii tui sicut novella olivarum in circuitu mensae tuae",
      "citation": "Psalms 128:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "ecce sic benedicetur homo qui timet Dominum",
      "citation": "Psalms 128:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "benedicat te Dominus ex Sion et videas bona Hierusalem omnibus diebus vitae tuae",
      "citation": "Psalms 128:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "et videas filios filiorum tuorum pax super Israhel",
      "citation": "Psalms 128:6 (Clementine Vulgate)"
    }
  ]
