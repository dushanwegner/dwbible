  "citation": "Psalms 124 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "canticum graduum huic David nisi quia Dominus erat in nobis dicat nunc Israhel",
      "citation": "Psalms 124:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "nisi quia Dominus erat in nobis cum exsurgerent in nos homines",
      "citation": "Psalms 124:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "forte vivos degluttissent nos cum irasceretur furor eorum in nos",
      "citation": "Psalms 124:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "forsitan aqua absorbuisset nos",
      "citation": "Psalms 124:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "torrentem pertransivit anima nostra forsitan pertransisset anima nostra aquam intolerabilem",
      "citation": "Psalms 124:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "benedictus Dominus qui non dedit nos in captionem dentibus eorum",
      "citation": "Psalms 124:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "anima nostra sicut passer erepta est de laqueo venantium laqueus contritus est et nos liberati sumus",
      "citation": "Psalms 124:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "adiutorium nostrum in nomine Domini qui fecit caelum et terram",
      "citation": "Psalms 124:8 (Clementine Vulgate)"
    }
  ]
