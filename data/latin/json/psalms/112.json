  "citation": "Psalms 112 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "alleluia reversionis Aggei et Zacchariae beatus vir qui timet Dominum in mandatis eius volet nimis",
      "citation": "Psalms 112:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "potens in terra erit semen eius generatio rectorum benedicetur",
      "citation": "Psalms 112:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "gloria et divitiae in domo eius et iustitia eius manet in saeculum saeculi",
      "citation": "Psalms 112:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "exortum est in tenebris lumen rectis misericors et miserator et iustus",
      "citation": "Psalms 112:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "iucundus homo qui miseretur et commodat disponet sermones suos in iudicio",
      "citation": "Psalms 112:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "quia in aeternum non commovebitur",
      "citation": "Psalms 112:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "in memoria aeterna erit iustus ab auditione mala non timebit paratum cor eius sperare in Domino",
      "citation": "Psalms 112:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "confirmatum est cor eius non commovebitur donec dispiciat inimicos suos",
      "citation": "Psalms 112:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "dispersit dedit pauperibus iustitia eius manet in saeculum saeculi cornu eius exaltabitur in gloria",
      "citation": "Psalms 112:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "peccator videbit et irascetur dentibus suis fremet et tabescet desiderium peccatorum peribit",
      "citation": "Psalms 112:10 (Clementine Vulgate)"
    }
  ]
}
