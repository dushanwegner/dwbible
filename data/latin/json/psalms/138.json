  "citation": "Psalms 138 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "ipsi David confitebor tibi Domine in toto corde meo quoniam audisti verba oris mei in conspectu angelorum psallam tibi",
      "citation": "Psalms 138:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "adorabo ad templum sanctum tuum et confitebor nomini tuo super misericordia tua et veritate tua quoniam magnificasti super omne nomen sanctum tuum",
      "citation": "Psalms 138:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "in quacumque die invocavero te exaudi me multiplicabis me in anima mea virtute",
      "citation": "Psalms 138:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "confiteantur tibi Domine omnes reges terrae quia audierunt omnia verba oris tui",
      "citation": "Psalms 138:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "et cantent in viis Domini quoniam magna gloria Domini",
      "citation": "Psalms 138:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "quoniam excelsus Dominus et humilia respicit et alta a longe cognoscit",
      "citation": "Psalms 138:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "si ambulavero in medio tribulationis vivificabis me super iram inimicorum meorum extendisti manum tuam et salvum me fecit dextera tua",
      "citation": "Psalms 138:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "Dominus retribuet propter me Domine misericordia tua in saeculum opera manuum tuarum ne dispicias",
      "citation": "Psalms 138:8 (Clementine Vulgate)"
    }
  ]
}
