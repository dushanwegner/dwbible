  "citation": "Psalms 97 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "huic David quando terra eius restituta est Dominus regnavit exultet terra laetentur insulae multae",
      "citation": "Psalms 97:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "nubes et caligo in circuitu eius iustitia et iudicium correctio sedis eius",
      "citation": "Psalms 97:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "ignis ante ipsum praecedet et inflammabit in circuitu inimicos eius",
      "citation": "Psalms 97:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "adluxerunt fulgora eius orbi terrae vidit et commota est terra",
      "citation": "Psalms 97:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "montes sicut cera fluxerunt *a facie Domini; a facie Domini omnis terrae",
      "citation": "Psalms 97:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "adnuntiaverunt caeli iustitiam eius et viderunt omnes populi gloriam eius",
      "citation": "Psalms 97:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "confundantur omnes qui adorant sculptilia qui gloriantur in simulacris suis adorate eum omnes angeli eius",
      "citation": "Psalms 97:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "audivit et laetata est Sion et exultaverunt filiae Iudaeae propter iudicia tua Domine",
      "citation": "Psalms 97:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "quoniam tu Dominus Altissimus super omnem terram nimis superexaltatus es super omnes deos",
      "citation": "Psalms 97:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "qui diligitis Dominum odite malum custodit animas sanctorum suorum de manu peccatoris liberabit eos",
      "citation": "Psalms 97:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "lux orta est iusto et rectis corde laetitia",
      "citation": "Psalms 97:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "laetamini iusti in Domino et confitemini memoriae sanctificationis eius",
      "citation": "Psalms 97:12 (Clementine Vulgate)"
    }
  ]
