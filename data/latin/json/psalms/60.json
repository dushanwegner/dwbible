  "citation": "Psalms 60 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "in finem his qui inmutabuntur in tituli inscriptione David in doctrina",
      "citation": "Psalms 60:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "Deus reppulisti nos et destruxisti nos iratus es et misertus es nobis",
      "citation": "Psalms 60:1 (Clementine Vulgate)"
    },
    {
      "verse": 1,
      "text": "in finem in hymnis David",
      "citation": "Psalms 60:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "commovisti terram et turbasti eam sana contritiones eius quia commota est",
      "citation": "Psalms 60:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "ostendisti populo tuo dura potasti nos vino conpunctionis",
      "citation": "Psalms 60:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "dedisti metuentibus te significationem ut fugiant a facie arcus diapsalma ut liberentur dilecti tui",
      "citation": "Psalms 60:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "salvum fac dextera tua et exaudi me",
      "citation": "Psalms 60:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "Deus locutus est in sancto suo laetabor et partibor Sicima et convallem tabernaculorum metibor",
      "citation": "Psalms 60:6 (Clementine Vulgate)"
    },
    {
      "verse": 7,
      "text": "meus est Galaad et meus Manasses et Effraim fortitudo capitis mei Iuda rex meus",
      "citation": "Psalms 60:7 (Clementine Vulgate)"
    },
    {
      "verse": 8,
      "text": "Moab olla spei meae in Idumeam extendam calciamentum meum mihi alienigenae subditi sunt",
      "citation": "Psalms 60:8 (Clementine Vulgate)"
    },
    {
      "verse": 9,
      "text": "quis deducet me in civitatem munitam quis deducet me usque in Idumeam",
      "citation": "Psalms 60:9 (Clementine Vulgate)"
    },
    {
      "verse": 10,
      "text": "nonne tu Deus qui reppulisti nos et non egredieris Deus in virtutibus nostris",
      "citation": "Psalms 60:10 (Clementine Vulgate)"
    },
    {
      "verse": 11,
      "text": "da nobis auxilium de tribulatione et vana salus hominis",
      "citation": "Psalms 60:11 (Clementine Vulgate)"
    },
    {
      "verse": 12,
      "text": "in Deo faciemus virtutem et ipse ad nihilum deducet tribulantes nos",
      "citation": "Psalms 60:12 (Clementine Vulgate)"
    }
  ]
