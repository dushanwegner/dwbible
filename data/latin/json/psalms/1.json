  "citation": "Psalms 1 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "beatus vir qui non abiit in consilio impiorum et in via peccatorum non stetit et in cathedra pestilentiae non sedit",
      "citation": "Psalms 1:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "sed in lege Domini voluntas eius et in lege eius meditabitur die ac nocte",
      "citation": "Psalms 1:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "et erit tamquam lignum quod plantatum est secus decursus aquarum quod fructum suum dabit in tempore suo et folium eius non defluet et omnia quaecumque faciet prosperabuntur",
      "citation": "Psalms 1:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "non sic impii sed tamquam pulvis quem proicit ventus",
      "citation": "Psalms 1:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "ideo non resurgent impii in iudicio neque peccatores in consilio iustorum",
      "citation": "Psalms 1:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "quoniam novit Dominus viam iustorum et iter impiorum peribit",
      "citation": "Psalms 1:6 (Clementine Vulgate)"
    }
  ]
