  "citation": "Joel 3 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "et erit post haec effundam spiritum meum super omnem carnem et prophetabunt filii vestri et filiae vestrae senes vestri somnia somniabunt et iuvenes vestri visiones videbunt",
      "citation": "Joel 3:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "sed et super servos et ancillas in diebus illis effundam spiritum meum",
      "citation": "Joel 3:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "et dabo prodigia in caelo et in terra sanguinem et ignem et vaporem fumi",
      "citation": "Joel 3:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "sol vertetur in tenebras et luna in sanguinem antequam veniat dies Domini magnus et horribilis",
      "citation": "Joel 3:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "et erit omnis qui invocaverit nomen Domini salvus erit quia in monte Sion et in Hierusalem erit salvatio sicut dixit Dominus et in residuis quos Dominus vocaverit",
      "citation": "Joel 3:5 (Clementine Vulgate)"
    }
  ]
