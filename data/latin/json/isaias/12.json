  "citation": "Isaiah 12 (Clementine Vulgate)",
  "verses": [
    {
      "verse": 1,
      "text": "et dices in illa die confitebor tibi Domine quoniam iratus es mihi conversus est furor tuus et consolatus es me",
      "citation": "Isaiah 12:1 (Clementine Vulgate)"
    },
    {
      "verse": 2,
      "text": "ecce Deus salvator meus fiducialiter agam et non timebo quia fortitudo mea et laus mea Dominus Deus et factus est mihi in salutem",
      "citation": "Isaiah 12:2 (Clementine Vulgate)"
    },
    {
      "verse": 3,
      "text": "haurietis aquas in gaudio de fontibus salvatoris",
      "citation": "Isaiah 12:3 (Clementine Vulgate)"
    },
    {
      "verse": 4,
      "text": "et dicetis in illa die confitemini Domino et invocate nomen eius notas facite in populis adinventiones eius mementote quoniam excelsum est nomen eius",
      "citation": "Isaiah 12:4 (Clementine Vulgate)"
    },
    {
      "verse": 5,
      "text": "cantate Domino quoniam magnifice fecit adnuntiate hoc in universa terra",
      "citation": "Isaiah 12:5 (Clementine Vulgate)"
    },
    {
      "verse": 6,
      "text": "exulta et lauda habitatio Sion quia magnus in medio tui Sanctus Israhel",
      "citation": "Isaiah 12:6 (Clementine Vulgate)"
    }
  ]
