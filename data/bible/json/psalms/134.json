  "verses": [
    {
      "verse": 1,
      "text": "A gradual canticle. Behold now bless ye the Lord, all ye servants of the Lord: Who stand in the house of the Lord, in the courts of the house of our God.",
      "citation": "Psalms 134:1 (Douay-Rheims)"
    },
    {
      "verse": 2,
      "text": "In the nights lift up your hands to the holy places, and bless ye the Lord.",
      "citation": "Psalms 134:2 (Douay-Rheims)"
    },
    {
      "verse": 3,
      "text": "May the Lord out of Sion bless thee, he that made heaven and earth.",
      "citation": "Psalms 134:3 (Douay-Rheims)"
    }
  ]
