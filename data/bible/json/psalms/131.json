  "verses": [
    {
      "verse": 1,
      "text": "A gradual canticle of David. Lord, my heart is not exalted: nor are my eyes lofty. Neither have I walked in great matters, nor in wonderful things above me.",
      "citation": "Psalms 131:1 (Douay-Rheims)"
    },
    {
      "verse": 2,
      "text": "If I was not humbly minded, but exalted my soul: As a child that is weaned is towards his mother, so reward in my soul.",
      "citation": "Psalms 131:2 (Douay-Rheims)"
    },
    {
      "verse": 3,
      "text": "Let Israel hope in the Lord, from henceforth now and for ever.",
      "citation": "Psalms 131:3 (Douay-Rheims)"
    }
  ]
